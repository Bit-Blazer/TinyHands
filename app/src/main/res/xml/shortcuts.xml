<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="toggle_protection"
        android:enabled="true"
        android:icon="@drawable/ic_lock"
        android:shortcutShortLabel="@string/shortcut_short_label"
        android:shortcutLongLabel="@string/shortcut_long_label">

        <intent
            android:action="com.bitblazer.tinyhands.ACTION_TOGGLE"
            android:targetPackage="com.bitblazer.tinyhands"
            android:targetClass="com.bitblazer.tinyhands.ShortcutHandlerActivity" />

        <categories android:name="android.shortcut.conversation" />

    </shortcut>

</shortcuts>
